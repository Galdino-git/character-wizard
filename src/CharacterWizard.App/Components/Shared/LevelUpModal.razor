@using CharacterWizard.Core.Models
@using CharacterWizard.Core.Rules
@using CharacterWizard.Data.Models
@using CharacterWizard.Data.Repositories
@inject ClassRepository ClassRepo
@inject SpellRepository SpellRepo

@if (Open && Char is not null && Entry is not null)
{
    var activeEntry = _multiclassEntry ?? Entry;
    var classData = _multiclassEntry is not null ? _multiclassClassData : _classData;

    <div class="cw-modal-backdrop" @onclick="Cancel"></div>
    <div class="cw-modal" role="dialog" aria-modal="true">
        <div class="cw-modal-header">
            <div>
                <div class="text-muted small text-uppercase">Subir nível</div>
                <h5 class="mb-0">
                    @(classData?.Name ?? "?") @(activeEntry.Levels)
                    @if (classData is not null) { <span>&rarr; @(activeEntry.Levels + 1)</span> }
                </h5>
            </div>
            <button class="cw-modal-close" @onclick="Cancel" aria-label="Fechar">✕</button>
        </div>

        <div class="d-flex gap-3 mb-2">
            <div class="form-check">
                <input type="radio" class="form-check-input" id="mode-existing-@_uid" name="mode-@_uid"
                       checked="@(!_multiclassMode)" @onchange="PickExistingMode" />
                <label class="form-check-label" for="mode-existing-@_uid">Subir @Entry.ClassRef.Name</label>
            </div>
            <div class="form-check">
                <input type="radio" class="form-check-input" id="mode-multi-@_uid" name="mode-@_uid"
                       checked="@_multiclassMode" @onchange="PickMulticlassMode" />
                <label class="form-check-label" for="mode-multi-@_uid">Adicionar classe (multiclass)</label>
            </div>
        </div>

        @if (_multiclassMode)
        {
            <div class="mb-2">
                <label class="form-label small mb-0">Classe nova</label>
                <select class="form-select form-select-sm" value="@_multiclassPick" @onchange="OnMulticlassClassChanged">
                    <option value="">— escolha —</option>
                    @foreach (var c in ClassRepo.All()
                        .Where(c => !Char.Classes.Any(e => e.ClassRef.Name == c.Name && e.ClassRef.Source == c.Source))
                        .OrderBy(c => c.Name))
                    {
                        <option value="@($"{c.Name}|{c.Source}")">@c.Name <span>· @c.Source</span></option>
                    }
                </select>
                <div class="alert alert-info small mt-2 mb-0">
                    Pré-requisitos RAW (STR/DEX/CHA 13 etc.) <strong>não</strong> são verificados.
                </div>
            </div>
        }

        @if (classData is null)
        {
            <div class="text-muted small">Selecione uma classe acima para continuar.</div>
            <div class="d-flex justify-content-end gap-2 mt-3">
                <button class="btn btn-sm btn-outline-secondary" @onclick="Cancel">Cancelar</button>
            </div>
        }
        else
        {
            var newLevel = activeEntry.Levels + 1;
            var conMod = AbilityScoreCalculator.Modifier(AbilityScoreCalculator.ComputeFinal(Char).Con);
            var hpGain = LevelUpRules.HpGainedAtLevel(newLevel,
                classData.HitDice?.Faces ?? 8, conMod, _hpMode, _manualRoll);

        <h6>HP</h6>
        <div class="d-flex gap-2 align-items-center mb-2">
            <select class="form-select form-select-sm" style="max-width: 9rem;" @bind="_hpMode">
                <option value="@HpMode.Average">Média</option>
                <option value="@HpMode.Maximum">Máximo</option>
                <option value="@HpMode.Manual">Manual</option>
            </select>
            @if (_hpMode == HpMode.Manual)
            {
                <input type="number" class="form-control form-control-sm" style="max-width: 6rem;" @bind="_manualRoll" />
            }
            <span class="small text-muted">→ HP ganho: <strong>@hpGain</strong> (incl. CON @(conMod >= 0 ? "+" : "")@conMod)</span>
        </div>

            var subLvl = classData.SubclassChoiceLevel() ?? 0;
            if (newLevel == subLvl && activeEntry.SubclassRef is null)
        {
            <h6 class="mt-3">Subclass <small class="text-muted">(escolha obrigatória)</small></h6>
            var subs = ClassRepo.SubclassesOf(activeEntry.ClassRef).OrderBy(s => s.Name).ToList();
            <select class="form-select form-select-sm" @bind="_subclassKey">
                <option value="">— escolha —</option>
                @foreach (var s in subs)
                {
                    var key = $"{s.Name}|{s.Source}";
                    <option value="@key">@s.Name <span>· @s.Source</span></option>
                }
            </select>
        }

        @if (LevelUpRules.IsAsiLevel(newLevel))
        {
            <h6 class="mt-3">ASI ou Feat</h6>
            <div class="form-check form-check-inline">
                <input type="radio" class="form-check-input" id="asi-asi-@_uid" name="asi-@_uid"
                       value="asi" checked="@(_asiOrFeat == "asi")"
                       @onchange="PickAsi" />
                <label class="form-check-label" for="asi-asi-@_uid">ASI</label>
            </div>
            <div class="form-check form-check-inline">
                <input type="radio" class="form-check-input" id="asi-feat-@_uid" name="asi-@_uid"
                       value="feat" checked="@(_asiOrFeat == "feat")"
                       @onchange="PickFeat" />
                <label class="form-check-label" for="asi-feat-@_uid">Feat</label>
            </div>

            @if (_asiOrFeat == "asi")
            {
                <div class="row g-2 mt-1">
                    @foreach (var a in (Ability[])Enum.GetValues(typeof(Ability)))
                    {
                        var captured = a;
                        <div class="col-4 col-md-2">
                            <label class="form-label small mb-0">@a.ToString().ToUpperInvariant()</label>
                            <input type="number" class="form-control form-control-sm" min="0" max="2"
                                   value="@(_asiAlloc.GetValueOrDefault(a))"
                                   @onchange="e => SetAsi(captured, e.Value)" />
                        </div>
                    }
                </div>
                <div class="small text-muted mt-1">Total alocado: @_asiAlloc.Values.Sum() (RAW: 2)</div>
            }
            else
            {
                <div class="d-flex gap-2 align-items-end mt-1">
                    <div class="flex-grow-1">
                        <label class="form-label small mb-0">Feat selecionada</label>
                        <input class="form-control form-control-sm" placeholder="(nenhuma)"
                               value="@DisplayFeat()" readonly />
                    </div>
                    <button class="btn btn-sm btn-outline-primary" @onclick="() => _featPickerOpen = true">
                        🔍 Escolher feat
                    </button>
                </div>
                <div class="row g-2 mt-1">
                    <div class="col-6">
                        <label class="form-label small mb-0">ou name manual</label>
                        <input class="form-control form-control-sm" placeholder="Feat name" @bind="_featName" />
                    </div>
                    <div class="col-3">
                        <label class="form-label small mb-0">source</label>
                        <input class="form-control form-control-sm" placeholder="PHB" @bind="_featSource" />
                    </div>
                </div>
            }
        }

            var gained = classData.FeaturesAtLevel(newLevel).ToList();
            var subclassGained = activeEntry.SubclassRef is { } srRef
                ? (ClassRepo.SubclassesOf(activeEntry.ClassRef)
                    .FirstOrDefault(s => s.Name == srRef.Name && s.Source == srRef.Source)
                    ?.FeaturesAtLevel(newLevel).ToList() ?? new())
                : new();
        @if (gained.Count > 0 || subclassGained.Count > 0)
        {
            <h6 class="mt-3">Features ganhas neste nível</h6>
            <ul class="small mb-0">
                @foreach (var n in gained)
                {
                    <li><strong>@n</strong> <span class="text-muted">— @classData.Name nv @newLevel</span></li>
                }
                @foreach (var n in subclassGained)
                {
                    <li><strong>@n</strong> <span class="text-muted">— @activeEntry.SubclassRef!.Value.Name nv @newLevel</span></li>
                }
            </ul>
        }

        @if (classData.IsCaster())
        {
            var oldLvl = activeEntry.Levels;
            var cantripDelta = classData.CantripsKnownAtLevel(newLevel) - classData.CantripsKnownAtLevel(oldLvl);
            var spellDelta   = classData.SpellsKnownAtLevel(newLevel)   - classData.SpellsKnownAtLevel(oldLvl);
            if (cantripDelta > 0 || spellDelta > 0)
            {
                <h6 class="mt-3">Aprender spells novos</h6>
                <p class="text-muted small mb-2">
                    Este nível concede @cantripDelta cantrip(s) e @spellDelta spell(s).
                    Marque até o limite.
                </p>

                @if (cantripDelta > 0)
                {
                    <div class="mb-2">
                        <div class="small fw-semibold mb-1">Cantrips (@_chosenCantrips.Count/@cantripDelta)</div>
                        <div class="list-group small" style="max-height: 160px; overflow:auto;">
                            @foreach (var sp in SpellRepo.ForClassAtLevel(classData.Name, classData.Source, 0)
                                .Where(s => !Char.KnownSpells.Any(k => k.Name == s.Name && k.Source == s.Source))
                                .OrderBy(s => s.Name).Take(40))
                            {
                                var spRef = new EntityRef(sp.Name, sp.Source);
                                var chosen = _chosenCantrips.Any(r => r.Name == spRef.Name && r.Source == spRef.Source);
                                <label class="list-group-item d-flex justify-content-between py-1" style="cursor:pointer">
                                    <span>
                                        <input type="checkbox" class="form-check-input me-2"
                                               checked="@chosen"
                                               disabled="@(!chosen && _chosenCantrips.Count >= cantripDelta)"
                                               @onchange="e => ToggleCantrip(spRef, (bool)(e.Value ?? false))" />
                                        @sp.Name <span class="text-muted">· @sp.Source</span>
                                    </span>
                                </label>
                            }
                        </div>
                    </div>
                }

                @if (spellDelta > 0)
                {
                    var maxSpellLvl = MaxSpellLevelForCaster(newLevel);
                    <div class="mb-2">
                        <div class="small fw-semibold mb-1">Spells (@_chosenSpells.Count/@spellDelta) — nível 1..@maxSpellLvl</div>
                        <div class="list-group small" style="max-height: 240px; overflow:auto;">
                            @for (int lvl = 1; lvl <= maxSpellLvl; lvl++)
                            {
                                foreach (var sp in SpellRepo.ForClassAtLevel(classData.Name, classData.Source, lvl)
                                    .Where(s => !Char.KnownSpells.Any(k => k.Name == s.Name && k.Source == s.Source))
                                    .OrderBy(s => s.Name).Take(60))
                                {
                                    var spRef = new EntityRef(sp.Name, sp.Source);
                                    var chosen = _chosenSpells.Any(r => r.Name == spRef.Name && r.Source == spRef.Source);
                                    <label class="list-group-item d-flex justify-content-between py-1" style="cursor:pointer">
                                        <span>
                                            <input type="checkbox" class="form-check-input me-2"
                                                   checked="@chosen"
                                                   disabled="@(!chosen && _chosenSpells.Count >= spellDelta)"
                                                   @onchange="e => ToggleSpell(spRef, (bool)(e.Value ?? false))" />
                                            <span class="badge bg-light text-dark me-1">nv @sp.Level</span>
                                            @sp.Name <span class="text-muted">· @sp.Source</span>
                                        </span>
                                    </label>
                                }
                            }
                        </div>
                    </div>
                }
            }
        }

            <div class="d-flex justify-content-end gap-2 mt-3">
                <button class="btn btn-sm btn-outline-secondary" @onclick="Cancel">Cancelar</button>
                <button class="btn btn-sm btn-primary" @onclick="Apply">Aplicar</button>
            </div>
        }
    </div>

    <FeatPickerModal Open="_featPickerOpen"
                     OnPick="OnFeatPicked"
                     OnCancel="() => _featPickerOpen = false" />
}

@code {
    [Parameter] public bool Open { get; set; }
    [Parameter] public Character? Char { get; set; }
    [Parameter] public CharacterClassEntry? Entry { get; set; }
    [Parameter] public EventCallback OnApplied { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private ClassData? _classData;
    private HpMode _hpMode = HpMode.Average;
    private int _manualRoll = 1;
    private string _subclassKey = "";
    private string _asiOrFeat = "asi";
    private Dictionary<Ability, int> _asiAlloc = new();
    private string _featName = "";
    private string _featSource = "";
    private bool _featPickerOpen;
    private readonly string _uid = Guid.NewGuid().ToString("N");

    // Multiclass state — when active, we operate on a transient entry that gets
    // appended to Char.Classes on Apply (instead of mutating the parent's Entry).
    private bool _multiclassMode;
    private string _multiclassPick = "";
    private CharacterClassEntry? _multiclassEntry;
    private ClassData? _multiclassClassData;

    private void PickExistingMode()
    {
        _multiclassMode = false;
        _multiclassEntry = null;
        _multiclassClassData = null;
        _multiclassPick = "";
    }

    private void PickMulticlassMode()
    {
        _multiclassMode = true;
    }

    private void OnMulticlassClassChanged(ChangeEventArgs e)
    {
        _multiclassPick = e.Value?.ToString() ?? "";
        var parts = _multiclassPick.Split('|');
        if (parts.Length != 2)
        {
            _multiclassEntry = null;
            _multiclassClassData = null;
            return;
        }
        var classRef = new EntityRef(parts[0], parts[1]);
        _multiclassClassData = ClassRepo.Find(classRef);
        _multiclassEntry = new CharacterClassEntry { ClassRef = classRef, Levels = 0 };
    }

    private string DisplayFeat() =>
        string.IsNullOrEmpty(_featName) ? "" : $"{_featName} ({_featSource})";

    private void OnFeatPicked(EntityRef r)
    {
        _featName = r.Name;
        _featSource = r.Source;
        _featPickerOpen = false;
    }

    protected override void OnParametersSet()
    {
        if (!Open || Entry is null) return;
        _classData = ClassRepo.Find(Entry.ClassRef);
        _hpMode = HpMode.Average;
        _subclassKey = "";
        _asiOrFeat = "asi";
        _asiAlloc = new();
        _featName = "";
        _featSource = "";
        _chosenCantrips = new();
        _chosenSpells = new();
    }

    private List<EntityRef> _chosenCantrips = new();
    private List<EntityRef> _chosenSpells = new();

    private void ToggleCantrip(EntityRef r, bool on)
    {
        if (on) { if (!_chosenCantrips.Contains(r)) _chosenCantrips.Add(r); }
        else _chosenCantrips.Remove(r);
    }
    private void ToggleSpell(EntityRef r, bool on)
    {
        if (on) { if (!_chosenSpells.Contains(r)) _chosenSpells.Add(r); }
        else _chosenSpells.Remove(r);
    }

    // Mirrors the table in SpellSelectStep — full caster slot progression. For
    // multiclass-via-this-modal we'd want effective caster level math but
    // single-class level-up matches this.
    private static int MaxSpellLevelForCaster(int characterLevel) => characterLevel switch
    {
        <= 2  => 1,
        <= 4  => 2,
        <= 6  => 3,
        <= 8  => 4,
        <= 10 => 5,
        <= 12 => 6,
        <= 14 => 7,
        <= 16 => 8,
        _     => 9,
    };

    private void PickAsi() => _asiOrFeat = "asi";
    private void PickFeat() => _asiOrFeat = "feat";

    private void SetAsi(Ability a, object? raw)
    {
        if (raw is null) return;
        if (int.TryParse(raw.ToString(), out var v))
            _asiAlloc[a] = Math.Clamp(v, 0, 2);
    }

    private Task Cancel() => OnCancel.InvokeAsync();

    private async Task Apply()
    {
        if (Char is null || Entry is null) return;

        // Resolve which entry is being modified and its backing class data.
        var activeEntry = _multiclassEntry ?? Entry;
        var classData = _multiclassEntry is not null ? _multiclassClassData : _classData;
        if (classData is null) return;

        var newLevel = activeEntry.Levels + 1;
        var conMod = AbilityScoreCalculator.Modifier(AbilityScoreCalculator.ComputeFinal(Char).Con);
        var hpGain = LevelUpRules.HpGainedAtLevel(newLevel,
            classData.HitDice?.Faces ?? 8, conMod, _hpMode, _manualRoll);

        activeEntry.HitPointRolls.Add(hpGain);
        activeEntry.Levels = newLevel;

        // Subclass pick when crossing the threshold
        var subLvl = classData.SubclassChoiceLevel() ?? 0;
        if (newLevel == subLvl && activeEntry.SubclassRef is null && _subclassKey.Length > 0)
        {
            var parts = _subclassKey.Split('|');
            if (parts.Length == 2) activeEntry.SubclassRef = new EntityRef(parts[0], parts[1]);
        }

        // Commit multiclass entry into the character (must happen before computing
        // totalLevel for ASI keys so the new class level counts).
        if (_multiclassEntry is not null && !Char.Classes.Contains(_multiclassEntry))
            Char.Classes.Add(_multiclassEntry);

        // ASI/feat — only on existing-class level-ups (RAW: ASIs are per-class-level).
        if (!_multiclassMode && LevelUpRules.IsAsiLevel(newLevel))
        {
            var totalLevel = Char.TotalLevel;
            var choice = new LevelChoices { AsiOrFeat = _asiOrFeat };
            if (_asiOrFeat == "asi") choice.AsiAllocation = new(_asiAlloc);
            else if (!string.IsNullOrWhiteSpace(_featName))
                choice.FeatRef = new EntityRef(_featName.Trim(),
                    string.IsNullOrWhiteSpace(_featSource) ? "PHB" : _featSource.Trim());
            Char.ChoicesByLevel[totalLevel] = choice;
        }

        // Spells learned this level-up
        foreach (var r in _chosenCantrips) if (!Char.KnownSpells.Contains(r)) Char.KnownSpells.Add(r);
        foreach (var r in _chosenSpells)   if (!Char.KnownSpells.Contains(r)) Char.KnownSpells.Add(r);

        await OnApplied.InvokeAsync();
    }
}
