@page "/new"
@using CharacterWizard.App.Components.Shared
@using CharacterWizard.App.Components.Wizard
@using CharacterWizard.App.Services
@using CharacterWizard.Core.Models
@using CharacterWizard.Core.Persistence
@using CharacterWizard.Data.Models
@using CharacterWizard.Data.Repositories
@using CharacterWizard.Data.Search
@inject CharacterDraft Draft
@inject CharacterStore Store
@inject SearchService Searcher
@inject RaceRepository RaceRepo
@inject ClassRepository ClassRepo
@inject NavigationManager Nav

<div class="d-flex justify-content-between align-items-start">
    <h1>Novo personagem</h1>
    <button class="btn btn-outline-primary btn-sm" @onclick="ToggleAssist">
        🔍 Compêndio
    </button>
</div>

@if (_assistOpen)
{
    <div class="card mb-3">
        <div class="card-body">
            <div class="d-flex gap-2 align-items-center mb-2">
                <input class="form-control form-control-sm" placeholder="Buscar entidade..."
                       value="@_assistQuery" @oninput="OnAssistInput" />
                <button class="btn btn-sm btn-link" @onclick="ToggleAssist">fechar</button>
            </div>
            @if (_assistResults is { } r && r.Items.Count > 0)
            {
                <div class="list-group list-group-flush small" style="max-height: 240px; overflow:auto;">
                    @foreach (var e in r.Items.Take(20))
                    {
                        <button class="list-group-item list-group-item-action py-1"
                                @onclick="() => OpenAssistDetail(e)">
                            <span class="badge bg-secondary me-2">@e.Category</span>
                            @e.Name <span class="text-muted">· @e.Source</span>
                        </button>
                    }
                </div>
            }
        </div>
    </div>
}

<EntityDetailPanel Open="_assistDetailOpen"
                   Category="@_assistDetailCat"
                   Ref="_assistDetailRef"
                   OnClose="() => _assistDetailOpen = false" />

@{
    var steps = BuildSteps();
    if (_stepIndex >= steps.Count) _stepIndex = steps.Count - 1;
    var current = steps[_stepIndex];
}

<ul class="nav nav-pills mb-3 flex-wrap">
    @for (int i = 0; i < steps.Count; i++)
    {
        var idx = i;
        var label = steps[i];
        <li class="nav-item">
            <button type="button"
                    class="nav-link @(idx == _stepIndex ? "active" : "")"
                    @onclick="() => _stepIndex = idx">
                @(idx + 1). @label
            </button>
        </li>
    }
</ul>

<div class="wizard-step">
    @switch (current)
    {
        case "Origem":       <BasicsStep />        break;
        case "Raça":         <RaceSelectStep />    break;
        case "Subraça":      <SubraceSelectStep /> break;
        case "Classe":       <ClassSelectStep />   break;
        case "Subclass":     <SubclassSelectStep /> break;
        case "Multiclass":   <MulticlassStep />    break;
        case "Background":   <BackgroundSelectStep /> break;
        case "Atributos":    <AbilitiesStep />     break;
        case "Spells":       <SpellSelectStep />   break;
        case "Equipamento":  <EquipmentStep />     break;
        case "Revisão":      <ReviewStep />        break;
    }
</div>

<div class="mt-4 d-flex justify-content-between">
    <button class="btn btn-outline-secondary" disabled="@(_stepIndex == 0)" @onclick="Prev">&larr; Voltar</button>
    @if (_stepIndex < steps.Count - 1)
    {
        <button class="btn btn-primary" @onclick="() => Next(steps.Count)">Avançar &rarr;</button>
    }
    else
    {
        <button class="btn btn-success" @onclick="Save">Salvar personagem</button>
    }
</div>

@code {
    private int _stepIndex;

    protected override void OnInitialized() => Draft.Reset();

    /// <summary>
    /// Steps are computed on every render based on Draft state. Conditional steps
    /// (Subraça, Subclass, Spells) appear when they're applicable; the user can
    /// navigate freely and selections in other steps are preserved by the Draft.
    /// </summary>
    private List<string> BuildSteps()
    {
        var s = new List<string> { "Origem", "Raça" };

        if (Draft.RaceRef is { } r && RaceRepo.SubracesOf(r).Any())
            s.Add("Subraça");

        s.Add("Classe");

        if (Draft.ClassRef is { } c &&
            ClassRepo.Find(c) is { } cls &&
            cls.SubclassChoiceLevel() is int lvl &&
            Draft.InitialLevel >= lvl)
        {
            s.Add("Subclass");
        }

        // Multiclass step is always offered (defaults empty); shows after the
        // primary class so users see it as an explicit "optional addition".
        if (Draft.ClassRef is not null)
            s.Add("Multiclass");

        s.Add("Background");
        s.Add("Atributos");

        if (Draft.ClassRef is { } cc &&
            ClassRepo.Find(cc) is { SpellcastingAbility: { Length: > 0 } })
        {
            s.Add("Spells");
        }

        s.Add("Equipamento");
        s.Add("Revisão");
        return s;
    }

    private void Next(int count) => _stepIndex = Math.Min(_stepIndex + 1, count - 1);
    private void Prev() => _stepIndex = Math.Max(_stepIndex - 1, 0);

    private void Save()
    {
        var c = Draft.ToCharacter();
        Store.Save(c);
        Nav.NavigateTo($"character/{c.Id}");
    }

    // Compêndio assist (F1.4)
    private bool _assistOpen;
    private string _assistQuery = "";
    private SearchResultPage? _assistResults;
    private CancellationTokenSource? _assistDebounce;
    private bool _assistDetailOpen;
    private string? _assistDetailCat;
    private EntityRef? _assistDetailRef;

    private void ToggleAssist() => _assistOpen = !_assistOpen;

    private async Task OnAssistInput(ChangeEventArgs e)
    {
        _assistQuery = e.Value?.ToString() ?? "";
        _assistDebounce?.Cancel();
        _assistDebounce = new();
        try
        {
            await Task.Delay(200, _assistDebounce.Token);
            _assistResults = Searcher.Search(_assistQuery, pageSize: 50);
            StateHasChanged();
        }
        catch (TaskCanceledException) { }
    }

    private void OpenAssistDetail(SearchEntry e)
    {
        _assistDetailCat = e.Category.ToLowerInvariant();
        _assistDetailRef = new EntityRef(e.Name, e.Source);
        _assistDetailOpen = true;
    }
}
