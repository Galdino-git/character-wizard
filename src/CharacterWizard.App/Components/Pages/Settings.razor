@page "/settings"
@using CharacterWizard.App.Services
@using CharacterWizard.Core.Settings
@using CharacterWizard.Data.Models
@using CharacterWizard.Data.Repositories
@inject AppSettings Cfg
@inject AppSettingsStore SettingsStore
@inject CatalogProvider Catalog
@inject BookRepository BookRepo
@inject RaceRepository RaceRepo
@inject ClassRepository ClassRepo
@inject SpellRepository SpellRepo
@inject ItemRepository ItemRepo

<h1>Configurações</h1>
<p class="text-muted">Habilite ou desabilite grupos de livros e fontes individuais.</p>

<div class="card mb-3">
    <div class="card-body py-2">
        <div class="form-check form-switch">
            <input type="checkbox" class="form-check-input" id="hide-reprints"
                   checked="@_hideReprints"
                   @onchange="e => _hideReprints = (bool)(e.Value ?? false)" />
            <label class="form-check-label" for="hide-reprints">
                <strong>Esconder versões antigas (reprints)</strong>
                <div class="small text-muted">
                    Quando um livro novo (ex.: XPHB) republica uma raça/classe/item do PHB, mostra só a versão nova.
                    Desligue se quiser ver lado a lado as duas edições.
                </div>
            </label>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body py-2 d-flex justify-content-between align-items-center">
        <div>
            <strong>Catálogo</strong>
            <div class="small text-muted">
                Recarregue se você atualizou os JSONs em <code>data/5etools-json/</code> via CLI.
            </div>
        </div>
        <div class="d-flex gap-2 align-items-center">
            @if (_reloadStatus is not null)
            {
                <span class="small text-success">@_reloadStatus</span>
            }
            <button class="btn btn-sm btn-outline-secondary" @onclick="ReloadCatalog">
                ↻ Recarregar catálogo
            </button>
        </div>
    </div>
</div>

<div class="row mb-3 text-center">
    <div class="col-6 col-md-3">
        <div class="border rounded p-2">
            <div class="small text-muted">Races</div>
            <div class="fs-5">@RaceRepo.All().Count()</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="border rounded p-2">
            <div class="small text-muted">Classes</div>
            <div class="fs-5">@ClassRepo.All().Count()</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="border rounded p-2">
            <div class="small text-muted">Spells</div>
            <div class="fs-5">@SpellRepo.All().Count()</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="border rounded p-2">
            <div class="small text-muted">Items</div>
            <div class="fs-5">@ItemRepo.All().Count()</div>
        </div>
    </div>
</div>

@foreach (var group in BookRepo.ByGroup().OrderBy(g => GroupOrder(g.Key)))
{
    var groupKey = group.Key;
    var groupEnabled = _enabledGroups.Contains(groupKey);
    var booksInGroup = group.ToList();
    var enabledInGroup = booksInGroup.Count(b => IsSourceEnabled(b.Source, groupEnabled));

    <div class="card mb-2">
        <div class="card-body py-2">
            <div class="d-flex justify-content-between align-items-center">
                <div class="form-check">
                    <input type="checkbox" class="form-check-input" id="g-@groupKey"
                           checked="@groupEnabled"
                           @onchange="e => ToggleGroup(groupKey, (bool)(e.Value ?? false))" />
                    <label class="form-check-label fw-semibold" for="g-@groupKey">
                        @GroupLabel(groupKey)
                        <span class="badge bg-light text-dark ms-2">@enabledInGroup / @booksInGroup.Count livros</span>
                    </label>
                </div>
                <div class="btn-group btn-group-sm">
                    <button class="btn btn-outline-secondary"
                            @onclick="() => SelectAllInGroup(booksInGroup, groupEnabled, true)">
                        Todos
                    </button>
                    <button class="btn btn-outline-secondary"
                            @onclick="() => SelectAllInGroup(booksInGroup, groupEnabled, false)">
                        Nenhum
                    </button>
                </div>
            </div>

            <div class="ms-4 mt-1 row">
                @foreach (var book in group.OrderBy(b => b.Name))
                {
                    var src = book.Source;
                    var srcEnabled = IsSourceEnabled(src, groupEnabled);
                    <div class="col-md-6">
                        <div class="form-check form-check-sm">
                            <input type="checkbox" class="form-check-input" id="s-@src"
                                   checked="@srcEnabled"
                                   @onchange="e => ToggleSource(src, groupEnabled, (bool)(e.Value ?? false))" />
                            <label class="form-check-label small" for="s-@src">
                                @book.Name <span class="text-muted">· @src</span>
                            </label>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

<div class="mt-3 d-flex gap-2">
    <button class="btn btn-primary" @onclick="SaveAndApply">Salvar e aplicar</button>
    @if (_status is not null)
    {
        <span class="align-self-center small text-success">@_status</span>
    }
</div>

@code {
    private HashSet<string> _enabledGroups = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> _enabledSourcesOverride = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> _disabledSourcesOverride = new(StringComparer.OrdinalIgnoreCase);
    private bool _hideReprints = true;
    private string? _status;
    private string? _reloadStatus;

    private void ReloadCatalog()
    {
        Catalog.Reload(Cfg);
        _reloadStatus = $"Recarregado: {Catalog.Catalog.Classes.Count} classes, {Catalog.Catalog.Spells.Count} spells.";
        StateHasChanged();
    }

    protected override void OnInitialized()
    {
        _enabledGroups = new(Cfg.EnabledGroups, StringComparer.OrdinalIgnoreCase);
        _enabledSourcesOverride = new(Cfg.EnabledSources, StringComparer.OrdinalIgnoreCase);
        _disabledSourcesOverride = new(Cfg.DisabledSources, StringComparer.OrdinalIgnoreCase);
        _hideReprints = Cfg.HideReprintedVersions;
    }

    private void SelectAllInGroup(List<BookInfo> books, bool groupEnabled, bool enable)
    {
        foreach (var b in books)
            ToggleSource(b.Source, groupEnabled, enable);
    }

    private void ToggleGroup(string key, bool on)
    {
        if (on) _enabledGroups.Add(key); else _enabledGroups.Remove(key);
    }

    private bool IsSourceEnabled(string source, bool groupEnabled)
    {
        if (_disabledSourcesOverride.Contains(source)) return false;
        if (_enabledSourcesOverride.Contains(source)) return true;
        return groupEnabled;
    }

    private void ToggleSource(string source, bool groupEnabled, bool on)
    {
        _disabledSourcesOverride.Remove(source);
        _enabledSourcesOverride.Remove(source);
        if (on && !groupEnabled)        _enabledSourcesOverride.Add(source);
        else if (!on && groupEnabled)   _disabledSourcesOverride.Add(source);
    }

    private void SaveAndApply()
    {
        Cfg.EnabledGroups   = _enabledGroups.ToList();
        Cfg.EnabledSources  = _enabledSourcesOverride.ToList();
        Cfg.DisabledSources = _disabledSourcesOverride.ToList();
        Cfg.HideReprintedVersions = _hideReprints;
        SettingsStore.Save(Cfg);
        Catalog.ApplySettings(Cfg);
        _status = "Aplicado.";
        StateHasChanged();
    }

    private static int GroupOrder(string key) => key switch
    {
        "core" => 0, "supplement" => 1, "supplement-alt" => 2,
        "setting" => 3, "setting-alt" => 4,
        "organized-play" => 5, "screen" => 6,
        "homecraft" => 7, "recipe" => 8, _ => 9,
    };

    private static string GroupLabel(string key) => key switch
    {
        "core" => "Core",
        "supplement" => "Supplements",
        "supplement-alt" => "Supplements (alt)",
        "setting" => "Campaign settings",
        "setting-alt" => "Settings (alt)",
        "organized-play" => "Organized play",
        "screen" => "DM screens",
        "homecraft" => "Homebrew",
        "recipe" => "Recipes",
        _ => key,
    };
}
