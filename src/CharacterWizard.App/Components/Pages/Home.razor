@page "/"
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Forms
@using CharacterWizard.Core.Models
@using CharacterWizard.Core.Persistence
@using CharacterWizard.Core.Rules
@using CharacterWizard.Core.Settings
@inject CharacterStore Store
@inject AppSettings Cfg
@inject NavigationManager Nav

<h1>Personagens</h1>

@if (Cfg.LastOpenedCharacterId is Guid lastId &&
     _characters.FirstOrDefault(c => c.Id == lastId) is { } last)
{
    <a class="btn btn-sm btn-outline-primary mb-2" href="character/@last.Id">
        ↻ Reabrir <strong>@last.Name</strong>
    </a>
}

@if (_characters.Count == 0)
{
    <div class="alert alert-secondary mt-3">
        Nenhum personagem ainda. <a href="new">Criar o primeiro &rarr;</a>
    </div>
}
else
{
    <div class="row g-3 mt-1 cw-grid">
        @foreach (var c in _characters)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 cw-pick" @onclick="() => Open(c.Id)">
                    <div class="card-body">
                        <h5 class="card-title">@c.Name</h5>
                        <p class="card-text mb-1">
                            <strong>Nível @c.TotalLevel</strong>
                            @if (c.RaceRef is { } r)
                            {
                                <span> · @r.Name</span>
                            }
                        </p>
                        <p class="card-text text-muted small">
                            @string.Join(" / ", c.Classes.Select(x => $"{x.ClassRef.Name} {x.Levels}"))
                        </p>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => Open(c.Id)">Abrir</button>
                    </div>
                </div>
            </div>
        }
    </div>
}

<div class="mt-4 d-flex gap-2 align-items-center">
    <a class="btn btn-primary" href="new">+ Novo personagem</a>
    <label class="btn btn-outline-secondary mb-0">
        Importar JSON
        <InputFile OnChange="OnImport" accept=".json" class="d-none" />
    </label>
    @if (_importStatus is not null)
    {
        <span class="small @(_importError ? "text-danger" : "text-success")">@_importStatus</span>
    }
</div>

@code {
    private List<Character> _characters = new();

    protected override void OnInitialized() =>
        _characters = Store.LoadAll().OrderByDescending(c => c.UpdatedUtc).ToList();

    private void Open(Guid id) => Nav.NavigateTo($"character/{id}");

    private string? _importStatus;
    private bool _importError;

    private async Task OnImport(InputFileChangeEventArgs e)
    {
        _importStatus = null;
        _importError = false;
        try
        {
            using var stream = e.File.OpenReadStream(maxAllowedSize: 4 * 1024 * 1024);
            var c = await JsonSerializer.DeserializeAsync<Character>(stream, new JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true,
            });
            if (c is null) throw new InvalidDataException("Arquivo vazio ou inválido.");

            // Give it a fresh Id to avoid colliding with existing files.
            var imported = c with { Id = Guid.NewGuid(), CreatedUtc = DateTime.UtcNow };
            Store.Save(imported);

            _characters = Store.LoadAll().OrderByDescending(x => x.UpdatedUtc).ToList();
            _importStatus = $"Importado: {imported.Name}";
        }
        catch (Exception ex)
        {
            _importError = true;
            _importStatus = "Falha ao importar: " + ex.Message;
        }
    }
}
