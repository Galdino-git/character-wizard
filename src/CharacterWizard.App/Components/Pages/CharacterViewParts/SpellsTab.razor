@using CharacterWizard.App.Components.Shared
@using CharacterWizard.Core.Models
@using CharacterWizard.Core.Rules
@using CharacterWizard.Data.Models
@using CharacterWizard.Data.Repositories
@inject ClassRepository ClassRepo
@inject SpellRepository SpellRepo

@{
    // For now we only support single-class caster slot display. Multiclass slot
    // math (effective caster level summing full/half/third casters) is harder
    // and isn't required for the gap list — deferred.
    var primaryCaster = Char.Classes.FirstOrDefault(e =>
        ClassRepo.Find(e.ClassRef)?.IsCaster() == true);
    var casterClass = primaryCaster is null ? null : ClassRepo.Find(primaryCaster.ClassRef);
    var casterLevel = primaryCaster?.Levels ?? 0;
    var slots = casterLevel > 0 ? SpellSlotTable.GetSlotRow(casterLevel) : new int[9];
}

@if (casterClass is null)
{
    <div class="text-muted">Personagem não tem classe conjuradora.</div>
}
else
{
    <h5>@casterClass.Name @casterLevel — spell slots</h5>
    <table class="table table-sm w-auto">
        <thead><tr>
            @for (int l = 1; l <= 9; l++) { <th class="text-center">Nv @l</th> }
        </tr></thead>
        <tbody><tr>
            @for (int l = 0; l < 9; l++)
            {
                <td class="text-center">@(slots[l] == 0 ? "—" : slots[l].ToString())</td>
            }
        </tr></tbody>
    </table>

    var abilityMod = AbilityScoreCalculator.Modifier(
        AbilityScoreCalculator.ComputeFinal(Char).Get(SpellcastingAbility(casterClass)));
    var preparedLimit = Math.Max(1, casterLevel + abilityMod);
    var pb = ProficiencyBonus.ForLevel(Char.TotalLevel);
    var dc = 8 + pb + abilityMod;
    var atk = pb + abilityMod;
    var usesPrep = UsesPrepared(casterClass.Name);

    <div class="small text-muted mb-3">
        Habilidade conjuradora: <strong>@SpellcastingAbility(casterClass).ToString().ToUpperInvariant()</strong>
        @(abilityMod >= 0 ? "+" : "")@abilityMod
        · Save DC: <strong>@dc</strong>
        · Atq de spell: <strong>@(atk >= 0 ? "+" : "")@atk</strong>
        @if (usesPrep)
        {
            <span> · Preparar até <strong>@preparedLimit</strong> spells</span>
        }
    </div>

    <div class="d-flex justify-content-between align-items-center mb-2">
        <h6 class="mb-0">Spells conhecidos</h6>
        <button class="btn btn-sm btn-primary" @onclick="() => _pickerOpen = true">+ Aprender spell</button>
    </div>

    @if (Char.KnownSpells.Count == 0)
    {
        <div class="text-muted small">Nenhum spell conhecido. Use o botão acima.</div>
    }
    else
    {
        @foreach (var group in Char.KnownSpells
            .Select(r => new { Ref = r, Data = SpellRepo.Find(r) })
            .Where(x => x.Data is not null)
            .GroupBy(x => x.Data!.Level)
            .OrderBy(g => g.Key))
        {
            var lvl = group.Key;
            var label = lvl == 0 ? "Cantrips" : $"Nível {lvl}";
            <h6 class="mt-3">@label</h6>
            <ul class="list-group small">
                @foreach (var item in group.OrderBy(x => x.Data!.Name))
                {
                    var spRef = item.Ref;
                    var prepared = Char.PreparedSpells.Contains(spRef);
                    <li class="list-group-item d-flex justify-content-between py-1">
                        <span>
                            @if (usesPrep && lvl > 0)
                            {
                                <input type="checkbox" class="form-check-input me-2"
                                       checked="@prepared"
                                       disabled="@(!prepared && PreparedCount() >= preparedLimit)"
                                       @onchange="e => TogglePrep(spRef, (bool)(e.Value ?? false))" />
                            }
                            @item.Data!.Name
                            <span class="text-muted ms-2">· @item.Data.Source</span>
                            @if (item.Data.School is not null)
                            {
                                <span class="badge bg-light text-dark ms-2">@item.Data.School</span>
                            }
                        </span>
                        <button class="btn btn-sm btn-link text-danger p-0" @onclick="() => Remove(spRef)">remover</button>
                    </li>
                }
            </ul>
        }

        @if (usesPrep)
        {
            <div class="small text-muted mt-2">
                Preparados: @PreparedCount() / @preparedLimit
            </div>
        }
    }
}

<SpellPickerModal Open="_pickerOpen" OnPick="OnSpellPicked" OnCancel="() => _pickerOpen = false" />

@code {
    [Parameter, EditorRequired] public Character Char { get; set; } = default!;
    [Parameter] public EventCallback OnChange { get; set; }

    private bool _pickerOpen;

    private int PreparedCount() => Char.PreparedSpells.Count;

    private static Ability SpellcastingAbility(ClassData c) => c.SpellcastingAbility?.ToLowerInvariant() switch
    {
        "int" => Ability.Int,
        "wis" => Ability.Wis,
        "cha" => Ability.Cha,
        _     => Ability.Int,
    };

    private static bool UsesPrepared(string className) => className switch
    {
        "Cleric" or "Druid" or "Paladin" or "Wizard" or "Artificer" => true,
        _ => false,
    };

    private async Task OnSpellPicked(EntityRef r)
    {
        if (!Char.KnownSpells.Contains(r)) Char.KnownSpells.Add(r);
        _pickerOpen = false;
        await OnChange.InvokeAsync();
    }

    private async Task Remove(EntityRef r)
    {
        Char.KnownSpells.Remove(r);
        Char.PreparedSpells.Remove(r);
        await OnChange.InvokeAsync();
    }

    private async Task TogglePrep(EntityRef r, bool on)
    {
        if (on)
        {
            if (!Char.PreparedSpells.Contains(r)) Char.PreparedSpells.Add(r);
        }
        else
        {
            Char.PreparedSpells.Remove(r);
        }
        await OnChange.InvokeAsync();
    }
}
