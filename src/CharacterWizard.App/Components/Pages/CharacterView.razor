@page "/character/{Id:guid}"
@using CharacterWizard.App.Components.Pages.CharacterViewParts
@using CharacterWizard.Core.Models
@using CharacterWizard.Core.Persistence
@using CharacterWizard.Core.Rules
@inject CharacterStore Store
@inject NavigationManager Nav

@if (_character is null)
{
    <div class="alert alert-warning">Personagem não encontrado.</div>
    <a class="btn btn-sm btn-outline-secondary" href="">&larr; Voltar</a>
}
else
{
    <div class="d-flex justify-content-between align-items-start">
        <div>
            <h1 class="mb-0">@_character.Name</h1>
            <div class="text-muted">
                @if (_character.RaceRef is { } r) { <span>@r.Name · </span> }
                @string.Join(" / ", _character.Classes.Select(x => $"{x.ClassRef.Name} {x.Levels}"))
                · Nível total @_character.TotalLevel
            </div>
        </div>
        <div>
            <button class="btn btn-sm btn-outline-danger" @onclick="Delete">Excluir</button>
            <a class="btn btn-sm btn-outline-secondary" href="">Voltar</a>
        </div>
    </div>

    <ul class="nav nav-tabs mt-3">
        @foreach (var t in _tabs)
        {
            var label = t;
            <li class="nav-item">
                <button type="button"
                        class="nav-link @(t == _activeTab ? "active" : "")"
                        @onclick="() => _activeTab = label">@t</button>
            </li>
        }
    </ul>

    <div class="border border-top-0 p-3">
        @switch (_activeTab)
        {
            case "Ficha":             <SheetTab Char="_character" /> break;
            case "Inventário":        <InventoryTab Char="_character" OnChange="HandleChange" /> break;
            case "Buffs & Notas":     <BuffsTab Char="_character" OnChange="HandleChange" /> break;
        }
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private Character? _character;
    private readonly string[] _tabs = { "Ficha", "Inventário", "Buffs & Notas" };
    private string _activeTab = "Ficha";

    protected override void OnParametersSet() => _character = Store.Load(Id);

    private void HandleChange()
    {
        if (_character is null) return;
        Store.Save(_character);
        StateHasChanged();
    }

    private void Delete()
    {
        if (_character is null) return;
        Store.Delete(_character.Id);
        Nav.NavigateTo("");
    }
}
