@page "/character/{Id:guid}"
@using System.Text.Json
@using CharacterWizard.App.Components.Pages.CharacterViewParts
@using CharacterWizard.App.Components.Shared
@using CharacterWizard.Core.Models
@using CharacterWizard.Core.Persistence
@using CharacterWizard.Core.Rules
@using CharacterWizard.Core.Settings
@inject CharacterStore Store
@inject AppSettings Cfg
@inject AppSettingsStore CfgStore
@inject NavigationManager Nav
@inject IJSRuntime JS

@if (_character is null)
{
    <div class="alert alert-warning">Personagem não encontrado.</div>
    <a class="btn btn-sm btn-outline-secondary" href="">&larr; Voltar</a>
}
else
{
    <div class="d-flex justify-content-between align-items-start">
        <div>
            <h1 class="mb-0">@_character.Name</h1>
            <div class="text-muted">
                @if (_character.RaceRef is { } r) { <span>@r.Name · </span> }
                @string.Join(" / ", _character.Classes.Select(x => $"{x.ClassRef.Name} {x.Levels}"))
                · Nível total @_character.TotalLevel
            </div>
        </div>
        <div>
            @if (_character.TotalLevel < 20 && _character.Classes.Count > 0)
            {
                <button class="btn btn-sm btn-primary me-2" @onclick="OpenLevelUp">+ Subir nível</button>
            }
            <button class="btn btn-sm btn-outline-secondary me-2" @onclick="Export">Exportar JSON</button>
            <button class="btn btn-sm btn-outline-danger" @onclick="Delete">Excluir</button>
            <a class="btn btn-sm btn-outline-secondary" href="">Voltar</a>
        </div>
    </div>

    <LevelUpModal Open="_levelUpOpen"
                  Char="_character"
                  Entry="_levelUpEntry"
                  OnApplied="OnLevelUpApplied"
                  OnCancel="() => _levelUpOpen = false" />

    <ul class="nav nav-tabs mt-3">
        @foreach (var t in _tabs)
        {
            var label = t;
            <li class="nav-item">
                <button type="button"
                        class="nav-link @(t == _activeTab ? "active" : "")"
                        @onclick="() => _activeTab = label">@t</button>
            </li>
        }
    </ul>

    <div class="border border-top-0 p-3">
        @switch (_activeTab)
        {
            case "Ficha":             <SheetTab Char="_character" /> break;
            case "Inventário":        <InventoryTab Char="_character" OnChange="HandleChange" /> break;
            case "Spells":            <SpellsTab Char="_character" OnChange="HandleChange" /> break;
            case "Buffs & Notas":     <BuffsTab Char="_character" OnChange="HandleChange" /> break;
        }
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private Character? _character;
    private readonly string[] _tabs = { "Ficha", "Inventário", "Spells", "Buffs & Notas" };
    private string _activeTab = "Ficha";

    protected override void OnParametersSet()
    {
        _character = Store.Load(Id);
        if (_character is not null && Cfg.LastOpenedCharacterId != _character.Id)
        {
            Cfg.LastOpenedCharacterId = _character.Id;
            CfgStore.Save(Cfg);
        }
    }

    private void HandleChange()
    {
        if (_character is null) return;
        Store.Save(_character);
        StateHasChanged();
    }

    private void Delete()
    {
        if (_character is null) return;
        Store.Delete(_character.Id);
        Nav.NavigateTo("");
    }

    // Level-up (F8) — single existing class entry; multiclass is M3.
    private bool _levelUpOpen;
    private CharacterClassEntry? _levelUpEntry;

    private void OpenLevelUp()
    {
        if (_character is null || _character.Classes.Count == 0) return;
        _levelUpEntry = _character.Classes[0];
        _levelUpOpen = true;
    }

    private async Task OnLevelUpApplied()
    {
        _levelUpOpen = false;
        await Task.Yield();
        HandleChange();
    }

    private async Task Export()
    {
        if (_character is null) return;
        var json = JsonSerializer.Serialize(_character, new JsonSerializerOptions
        {
            WriteIndented = true,
            DefaultIgnoreCondition = System.Text.Json.Serialization.JsonIgnoreCondition.WhenWritingNull,
        });
        var safeName = string.Join("_",
            (_character.Name ?? "character").Split(Path.GetInvalidFileNameChars()));
        await JS.InvokeVoidAsync("cwIo.download", $"{safeName}.json", json);
    }
}
