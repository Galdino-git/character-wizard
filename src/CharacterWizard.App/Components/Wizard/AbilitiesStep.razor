@using CharacterWizard.App.Services
@using CharacterWizard.Core.Models
@using CharacterWizard.Core.Rules
@inject CharacterDraft Draft

<h3>Atributos</h3>
<p class="text-muted">
    Defina os atributos base. Bônus de raça, ASIs e overrides serão aplicados depois.
</p>

<div class="row g-3" style="max-width: 36rem;">
    @foreach (var a in (Ability[])Enum.GetValues(typeof(Ability)))
    {
        <div class="col-6 col-md-4">
            <label class="form-label">@a.ToString().ToUpperInvariant()</label>
            <input type="number" class="form-control" min="1" max="30"
                   value="@Draft.BaseAbilityScores.Get(a)"
                   @onchange="e => Set(a, e.Value)" />
            <div class="form-text">Mod: @Fmt(AbilityScoreCalculator.Modifier(Draft.BaseAbilityScores.Get(a)))</div>
        </div>
    }
</div>

<div class="mt-3 d-flex gap-2">
    <button class="btn btn-outline-secondary btn-sm"
            @onclick="() => Apply(15,14,13,12,10,8)">Standard array</button>
    <button class="btn btn-outline-secondary btn-sm"
            @onclick="() => Apply(10,10,10,10,10,10)">Tudo 10</button>
</div>

@code {
    private void Set(Ability a, object? raw)
    {
        if (raw is null) return;
        if (int.TryParse(raw.ToString(), out var v))
            Draft.BaseAbilityScores = Draft.BaseAbilityScores.With(a, v);
    }

    private void Apply(int s, int d, int c, int i, int w, int ch)
    {
        Draft.BaseAbilityScores = new AbilityScores
        { Str = s, Dex = d, Con = c, Int = i, Wis = w, Cha = ch };
    }

    private static string Fmt(int mod) => mod >= 0 ? $"+{mod}" : mod.ToString();
}
