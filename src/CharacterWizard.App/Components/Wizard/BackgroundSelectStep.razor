@using CharacterWizard.App.Components.Shared
@using CharacterWizard.App.Services
@using CharacterWizard.Core.Models
@using CharacterWizard.Data.EntryRendering
@using CharacterWizard.Data.Models
@using CharacterWizard.Data.Repositories
@inject CharacterDraft Draft
@inject BackgroundRepository BgRepo
@inject ImageService Images

<h3>Background</h3>

<div class="row">
    <div class="col-lg-8">
        <div class="mb-3" style="max-width: 22rem;">
            <input class="form-control form-control-sm" placeholder="Filtrar..."
                   @bind="_filter" @bind:event="oninput" />
        </div>

        <div class="row g-3">
            @foreach (var b in Filtered())
            {
                var selected = Draft.BackgroundRef is { Name: var n, Source: var s }
                            && n == b.Name && s == b.Source;
                var img = Images.GetBackgroundImage(b.Name, b.Source);

                <div class="col-md-6 col-xl-4">
                    <div class="card h-100 @(selected ? "border-primary" : "")"
                         style="cursor:pointer" @onclick="() => Pick(b)">
                        @if (img is not null)
                        {
                            <img src="@img" class="card-img-top"
                                 style="object-fit:cover; height:100px;" alt="@b.Name" />
                        }
                        else
                        {
                            <div class="card-img-top bg-secondary"
                                 style="height:100px; opacity:0.2;"></div>
                        }
                        <div class="card-body p-2">
                            <div class="fw-semibold">@b.Name</div>
                            <div class="small text-muted">@b.Source</div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="col-lg-4">
        @if (Selected() is { } sel)
        {
            <div class="border rounded p-3 sticky-top" style="top:1rem;">
                <h5 class="mb-1">@sel.Name</h5>
                <div class="small text-muted mb-2">@sel.Source@(sel.Page is int p ? $" · p. {p}" : "")</div>
                @if (sel.Entries.HasValue)
                {
                    <EntryDisplay Entries="sel.Entries" />
                }
                <button class="btn btn-sm btn-outline-secondary mt-2" @onclick="() => OpenDetail(sel)">
                    ⓘ Detalhe completo
                </button>
            </div>
        }
        else
        {
            <div class="text-muted small p-3">Selecione um background à esquerda para ver detalhes.</div>
        }
    </div>
</div>

<EntityDetailPanel Open="_detailOpen" Category="Background" Ref="_detailRef" OnClose="CloseDetail" />

@code {
    private string _filter = "";
    private bool _detailOpen;
    private EntityRef? _detailRef;

    private BackgroundData? Selected() =>
        Draft.BackgroundRef is { } b ? BgRepo.Find(b) : null;

    private IEnumerable<BackgroundData> Filtered() =>
        BgRepo.All()
            .Where(b => string.IsNullOrEmpty(_filter) ||
                        b.Name.Contains(_filter, StringComparison.OrdinalIgnoreCase))
            .OrderBy(b => b.Name)
            .Take(100);

    private void Pick(BackgroundData b) =>
        Draft.BackgroundRef = new EntityRef(b.Name, b.Source);

    private void OpenDetail(BackgroundData b)
    {
        _detailRef = new EntityRef(b.Name, b.Source);
        _detailOpen = true;
    }
    private void CloseDetail() => _detailOpen = false;
}
