@using CharacterWizard.App.Components.Shared
@using CharacterWizard.App.Services
@using CharacterWizard.Core.Models
@using CharacterWizard.Data.EntryRendering
@using CharacterWizard.Data.Models
@using CharacterWizard.Data.Repositories
@inject CharacterDraft Draft
@inject RaceRepository RaceRepo
@inject ImageService Images

<h3>Raça</h3>

<div class="row">
    <div class="col-lg-8">
        <div class="mb-3" style="max-width: 22rem;">
            <input class="form-control form-control-sm" placeholder="Filtrar..."
                   @bind="_filter" @bind:event="oninput" />
        </div>

        <div class="row g-3 cw-grid">
            @foreach (var r in Filtered())
            {
                var selected = Draft.RaceRef is { Name: var n, Source: var s }
                            && n == r.Name && s == r.Source;
                var img = Images.GetRaceImage(r.Name, r.Source);

                <div class="col-md-6 col-xl-4">
                    <div class="card h-100 cw-pick @(selected ? "cw-pick--selected border-primary" : "")"
                         @onclick="() => Pick(r)">
                        @if (selected) { <span class="cw-burst"></span> }
                        @if (img is not null)
                        {
                            <img src="@img" class="card-img-top"
                                 style="object-fit:cover; height:120px;" alt="@r.Name" />
                        }
                        else
                        {
                            <div class="card-img-top bg-secondary"
                                 style="height:120px; opacity:0.2;"></div>
                        }
                        <div class="card-body p-2">
                            <div class="fw-semibold">@r.Name</div>
                            <div class="small text-muted">@r.Source</div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="col-lg-4">
        @if (Selected() is { } sel)
        {
            <div class="border rounded p-3 sticky-top" style="top:1rem;">
                <h5 class="mb-1">@sel.Name</h5>
                <div class="small text-muted mb-2">@sel.Source@(sel.Page is int p ? $" · p. {p}" : "")</div>
                @if (sel.Entries.HasValue)
                {
                    <EntryDisplay Entries="sel.Entries" />
                }
                <button class="btn btn-sm btn-outline-secondary mt-2" @onclick="() => OpenDetail(sel)">
                    ⓘ Detalhe completo
                </button>
            </div>
        }
        else
        {
            <div class="text-muted small p-3">Selecione uma raça à esquerda para ver detalhes.</div>
        }
    </div>
</div>

<EntityDetailPanel Open="_detailOpen" Category="Race" Ref="_detailRef" OnClose="CloseDetail" />

@code {
    private string _filter = "";

    private bool _detailOpen;
    private EntityRef? _detailRef;

    private RaceData? Selected() =>
        Draft.RaceRef is { } r ? RaceRepo.Find(r) : null;

    private void OpenDetail(RaceData r)
    {
        _detailRef = new EntityRef(r.Name, r.Source);
        _detailOpen = true;
    }
    private void CloseDetail() => _detailOpen = false;

    private IEnumerable<RaceData> Filtered() =>
        RaceRepo.All()
            .Where(r => string.IsNullOrEmpty(_filter) ||
                        r.Name.Contains(_filter, StringComparison.OrdinalIgnoreCase))
            .OrderBy(r => r.Name)
            .Take(100);

    private void Pick(RaceData r) =>
        Draft.RaceRef = new EntityRef(r.Name, r.Source);
}
